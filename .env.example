# ============================================================
#  Trading Bot environment configuration
#  Copy this file to ".env" and fill in your real values.
#  The bot runs in Paper/Simulation mode even if these are blank.
# ============================================================

# ---- MongoDB (optional; falls back to local JSON if unreachable) ----
MONGO_URI="mongodb://localhost:27017/"
MONGO_DB_NAME="trading_bot"

# ---- Upstox (Paper via Sandbox + Live) ----
UPSTOX_SANDBOX_TOKEN=""
UPSTOX_LIVE_ACCESS_TOKEN=""
UPSTOX_LIVE_API_KEY=""
UPSTOX_LIVE_SECRET=""
# Must EXACTLY match the Redirect URI registered in your Upstox app.
# Used by get_token.py to generate the daily live access token.
UPSTOX_REDIRECT_URI="https://127.0.0.1:5000/"

# ---- Dhan (Live) ----
DHAN_CLIENT_ID=""
DHAN_ACCESS_TOKEN=""

# ---- Kotak Neo (Live) ----
KOTAK_NEO_CONSUMER_KEY=""
KOTAK_NEO_CONSUMER_SECRET=""
KOTAK_NEO_ACCESS_TOKEN=""
KOTAK_NEO_MOBILE=""
KOTAK_NEO_PASSWORD=""

# ---- Global risk / capital defaults ----
TOTAL_CAPITAL="100000"
